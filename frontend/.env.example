# =============================================================================
# DASHBOARD AZO FRONTEND - ENVIRONMENT VARIABLES
# =============================================================================
# ⚠️  SEGURANÇA: Nunca commit este arquivo com valores reais!
# Use .env.local para desenvolvimento e configure no Vercel para produção
# =============================================================================

# 🌐 NEXT.JS CONFIGURATION
NEXT_PUBLIC_APP_NAME="Dashboard AZO"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_ENVIRONMENT=production

# 🔗 API CONFIGURATION
NEXT_PUBLIC_API_URL=https://api.dashboard.azo.inc
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_API_TIMEOUT=30000

# 🔥 FIREBASE CLIENT CONFIGURATION (Frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# 📊 ANALYTICS & MONITORING
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_HOTJAR_ID=123456
NEXT_PUBLIC_CLARITY_ID=abcdef123456

# 🎨 UI/UX CONFIGURATION
NEXT_PUBLIC_THEME=light
NEXT_PUBLIC_DEFAULT_LANGUAGE=pt-BR
NEXT_PUBLIC_COMPANY_NAME="AZO INC"
NEXT_PUBLIC_COMPANY_LOGO=/logo.svg

# 🚀 PERFORMANCE CONFIGURATION
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_LAZY_LOADING=true
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true

# 🔒 SECURITY CONFIGURATION
NEXT_PUBLIC_ENABLE_CSP=true
NEXT_PUBLIC_CORS_MODE=strict
NEXT_PUBLIC_SESSION_TIMEOUT=1800000

# 📱 PWA CONFIGURATION
NEXT_PUBLIC_PWA_NAME="Dashboard AZO"
NEXT_PUBLIC_PWA_SHORT_NAME="AZO"
NEXT_PUBLIC_PWA_DESCRIPTION="Sistema de gestão empresarial AZO"
NEXT_PUBLIC_PWA_THEME_COLOR="#1e40af"
NEXT_PUBLIC_PWA_BACKGROUND_COLOR="#ffffff"

# 🌍 LOCALIZATION
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SUPPORTED_LOCALES=pt-BR,en-US
NEXT_PUBLIC_FALLBACK_LOCALE=pt-BR

# 📧 CONTACT & SUPPORT
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@azo.inc
NEXT_PUBLIC_SUPPORT_PHONE=+55-21-1234-5678
NEXT_PUBLIC_HELP_URL=https://help.azo.inc

# 🔍 DEBUG & DEVELOPMENT (APENAS DEV)
if NEXT_PUBLIC_ENVIRONMENT=development:
  NEXT_PUBLIC_API_URL=http://localhost:8000
  NEXT_PUBLIC_ENABLE_DEBUG=true
  NEXT_PUBLIC_LOG_LEVEL=debug
  NEXT_PUBLIC_ENABLE_MOCKS=true

# 🚀 PRODUCTION SPECIFIC
if NEXT_PUBLIC_ENVIRONMENT=production:
  NEXT_PUBLIC_ENABLE_DEBUG=false
  NEXT_PUBLIC_LOG_LEVEL=error
  NEXT_PUBLIC_CACHE_ENABLED=true
  NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true

# 📊 BUSINESS LOGIC
NEXT_PUBLIC_DEFAULT_TIMEZONE="America/Sao_Paulo"
NEXT_PUBLIC_DEFAULT_CURRENCY=BRL
NEXT_PUBLIC_DATE_FORMAT=DD/MM/YYYY
NEXT_PUBLIC_TIME_FORMAT=HH:mm

# 🎯 FEATURE FLAGS
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=false
