# Application
APP_NAME="Dashboard AZO Backend"
APP_VERSION="0.1.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/supabase_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./serviceAccount.json

# Supabase Integration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# External APIs - Sienge (baseado na implementação existente)
SIENGE_SUBDOMAIN=your_subdomain
SIENGE_API_TOKEN=your_sienge_token

META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token

GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_refresh_token

# Security
SECRET_KEY=your_super_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Seed Admin User (Mestre do Universo)
ADMIN_SEED_EMAIL=mestre@azo.inc
ADMIN_SEED_PASSWORD=change_this_password_123

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "https://your-domain.vercel.app"]
