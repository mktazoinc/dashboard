# =============================================================================
# DASHBOARD AZO - ENVIRONMENT VARIABLES
# =============================================================================
# ⚠️  SEGURANÇA: Nunca commit este arquivo com valores reais!
# Use .env.local para desenvolvimento e configure no Vercel para produção
# =============================================================================

# 🏗️ APPLICATION CONFIGURATION
APP_NAME="Dashboard AZO Backend"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# 🗄️ DATABASE CONFIGURATION
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dashboard_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# 🔄 REDIS CONFIGURATION (Cache e Rate Limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_RATE_LIMIT_TTL=300

# 🔥 FIREBASE CONFIGURATION (Método 1: Environment Variables - RECOMENDADO)
FIREBASE_PROJECT_ID=seu_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@seu_project.iam.gserviceaccount.com

# 🔥 FIREBASE CONFIGURATION (Método 2: Arquivo JSON - Alternativa)
# FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./serviceAccount.json

# 📊 SUPABASE INTEGRATION (Marketing Leads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_POOL_SIZE=10

# 🔌 EXTERNAL APIS
SIENGE_SUBDOMAIN=your_subdomain
SIENGE_API_TOKEN=your_sienge_token

META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token

GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_refresh_token

# 🛡️ SECURITY CONFIGURATION
SECRET_KEY=your_super_secret_key_here_minimum_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 🚦 RATE LIMITING (CRÍTICO - Baseado no pentest)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_LOGIN_REQUESTS_PER_MINUTE=5
RATE_LIMIT_LOGIN_BURST=2

# 🌐 CORS CONFIGURATION (Seguro)
CORS_ALLOWED_ORIGINS=["https://dashboard.azo.inc", "https://dashboard-azo.vercel.app"]
CORS_ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOWED_HEADERS=["Authorization", "Content-Type", "X-Requested-With"]
CORS_ALLOW_CREDENTIALS=true

# 🔒 SECURITY HEADERS (Proteção XSS/Clickjacking)
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_DEFAULT_SRC="'self'"
SECURITY_CSP_SCRIPT_SRC="'self'"
SECURITY_CSP_STYLE_SRC="'self' 'unsafe-inline'"
SECURITY_CSP_IMG_SRC="'self' data: https:"
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true

# 📝 LOGGING CONFIGURATION
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# 📊 MONITORING & HEALTH CHECKS
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# 👤 ADMIN SEED USER
ADMIN_SEED_EMAIL=mestre@azo.inc
ADMIN_SEED_PASSWORD=change_this_password_123_minimum_8_chars
ADMIN_SEED_ROLE=mestre_do_universo

# 🏢 BUSINESS CONFIGURATION
COMPANY_NAME="AZO INC"
COMPANY_DOMAIN="azo.inc"
DEFAULT_TIMEZONE="America/Sao_Paulo"
DEFAULT_CURRENCY="BRL"

# 📧 EMAIL CONFIGURATION (Opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@azo.inc
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true

# 📱 NOTIFICATIONS
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# 🔍 DEBUG & DEVELOPMENT (APENAS DEV)
if ENVIRONMENT=development:
  DEBUG=true
  LOG_LEVEL=DEBUG
  RATE_LIMIT_ENABLED=false
  SECURITY_HEADERS_ENABLED=false
  CORS_ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 🚀 PRODUCTION SPECIFIC
if ENVIRONMENT=production:
  DEBUG=false
  LOG_LEVEL=WARNING
  RATE_LIMIT_ENABLED=true
  SECURITY_HEADERS_ENABLED=true
  DATABASE_POOL_SIZE=50
  DATABASE_MAX_OVERFLOW=100
